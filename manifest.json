{
  "id": "disney_parks_times",
  "name": "Disney Parks Queue Times",
  "version": "1.1.0",
  "description": "Display wait times for Disney parks (Disneyland, California Adventure, Disney World, etc.) from Queue-Times.com",
  "author": "FiestaBoard Team",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--disney-parks-times",
  "documentation": "README.md",
  "icon": "landmark",
  "category": "entertainment",
  "min_refresh_seconds": 60,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Disney Parks Queue Times",
        "default": false
      },
      "parks": {
        "type": "array",
        "title": "Parks and rides",
        "description": "Select one or more Disney parks and the rides to show wait times for.",
        "ui:widget": "disney-parks-times-picker",
        "items": {
          "type": "object",
          "properties": {
            "park_id": {
              "type": "integer",
              "title": "Park"
            },
            "ride_ids": {
              "type": "array",
              "title": "Rides",
              "items": {
                "type": "integer"
              }
            }
          },
          "required": [
            "park_id",
            "ride_ids"
          ]
        }
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh interval (seconds)",
        "default": 300,
        "minimum": 60
      }
    },
    "required": [
      "parks"
    ]
  },
  "env_vars": [],
  "variables": {
    "groups": {
      "display": {
        "label": "Display"
      }
    },
    "simple": {
      "formatted": {
        "description": "Pre-formatted ride wait times display",
        "type": "string",
        "max_length": 22,
        "group": "display",
        "example": "Space Mtn: 45m"
      }
    },
    "arrays": {
      "parks": {
        "label_field": "park_name",
        "item_fields": [
          "park_name"
        ],
        "sub_arrays": {
          "rides": {
            "label_field": "ride_name",
            "item_fields": [
              "ride_name",
              "ride_abbr",
              "tiny_abbr",
              "wait_time",
              "is_open",
              "status",
              "state_color",
              "formatted"
            ]
          }
        }
      }
    },
    "dynamic": false
  },
  "max_lengths": {
    "parks.*.park_name": 22,
    "parks.*.rides.*.ride_name": 22,
    "parks.*.rides.*.ride_abbr": 14,
    "parks.*.rides.*.tiny_abbr": 5,
    "parks.*.rides.*.wait_time": 3,
    "parks.*.rides.*.status": 10,
    "parks.*.rides.*.state_color": 4,
    "parks.*.rides.*.formatted": 22
  },
  "fiestaboard_version": ">=2.10.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Disney Parks Queue Times displayed on a Vestaboard",
      "caption": "Display wait times for Disney parks (Disneyland, California Adventure, Disney World, etc.) from Queue-Times.com",
      "primary": true
    }
  ],
  "demo": {
    "name": "Disney Wait Times Demo",
    "device_type": "flagship",
    "template": [
      "{{disney_parks_times.parks.0.park_name}}",
      "{{disney_parks_times.formatted}}",
      "",
      "",
      "",
      ""
    ],
    "line_metadata": [
      {
        "alignment": "center",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": true
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      }
    ]
  }
}
